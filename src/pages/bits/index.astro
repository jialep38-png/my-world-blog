---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayCard from '../../components/EssayCard.astro';
import { createWithBase, getEssaySlug, getLearningEssays } from '../../lib/content';
import { getListExcerpt } from '../../utils/excerpt';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const learningEssays = await getLearningEssays();
---

<BaseLayout title="笔记">
  <div class="page-header page-header--bits">
    <h1 class="page-title">笔记</h1>
    <span class="page-subtitle">项目复盘与实践记录，共 {learningEssays.length} 篇</span>
  </div>

  <div class="bits-toolbar">
    <div class="bits-controls">
      <div class="bits-search">
        <label class="sr-only" for="bits-search">搜索笔记</label>
        <input
          id="bits-search"
          type="search"
          placeholder="搜索：关键词 / 标签（例如 Python）"
          autocomplete="off"
        />
        <button class="bits-search-btn" id="bits-search-btn" type="button">搜索</button>
      </div>
    </div>
    <div class="bits-status" id="bits-search-status" role="status" aria-live="polite"></div>
  </div>

  <div class="bits-toolbar bits-toolbar--compact">
    <div class="bits-status">提示：笔记文章支持在 Frontmatter 的 `tags` 中填写标签，搜索会命中全部标签。</div>
  </div>

  <div id="bits-list" class="list">
    {learningEssays.map((entry) => (
      <div data-bit data-slug={getEssaySlug(entry)}>
        <EssayCard
          href={withBase(`/archive/${getEssaySlug(entry)}/`)}
          slug={getEssaySlug(entry)}
          title={entry.data.title}
          excerpt={getListExcerpt(entry)}
          date={entry.data.date}
          tags={entry.data.tags ?? []}
          badge="笔记"
        />
      </div>
    ))}
  </div>

  <script>
    import '../../scripts/bits-search.ts';
  </script>
</BaseLayout>
