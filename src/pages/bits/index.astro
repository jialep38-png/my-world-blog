---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import EssayCard from '../../components/EssayCard.astro';
import { createWithBase, getEssaySlug, getLearningEssays } from '../../lib/content';
import { getListExcerpt } from '../../utils/excerpt';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const learningEssays = await getLearningEssays();
---

<BaseLayout title="学习记录" bodyClass="essay-page">
  <div class="page-header page-header--bits page-header--with-search">
    <div class="page-heading">
      <h1 class="page-title">学习记录</h1>
      <span class="page-subtitle">项目复盘与实践记录，共 {learningEssays.length} 篇</span>
    </div>
    <div class="page-actions">
      <div class="entry-search" data-entry-search data-index-url={withBase('/bits/index.json')}>
        <div class="entry-search-panel" data-entry-search-panel aria-hidden="true">
          <input
            data-entry-search-input
            type="search"
            placeholder="搜索：标题 / 摘要 / 标签"
            autocomplete="off"
            aria-label="搜索学习记录"
          />
        </div>
        <button
          class="entry-search-toggle"
          data-entry-search-toggle
          type="button"
          aria-label="搜索学习记录"
          title="搜索"
          aria-expanded="false"
        >
          <Icon name="search" class="icon" />
        </button>
      </div>
    </div>
  </div>
  <div class="entry-status" data-entry-search-status role="status" aria-live="polite"></div>

  <div class="list">
    {learningEssays.map((entry) => (
      <EssayCard
        href={withBase(`/archive/${getEssaySlug(entry)}/`)}
        slug={getEssaySlug(entry)}
        title={entry.data.title}
        excerpt={getListExcerpt(entry)}
        date={entry.data.date}
        tag={entry.data.tags?.[0]}
        badge="学习记录"
      />
    ))}
  </div>

  <script>
    import '../../scripts/entry-search.ts';
  </script>
</BaseLayout>
