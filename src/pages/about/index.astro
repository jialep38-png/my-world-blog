---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { quickLinkSections } from '../../lib/site-sections';
import { createWithBase } from '../../utils/format';

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
---

<BaseLayout title="关于" bodyClass="about-page">
  <div class="page-header page-header--about">
    <h1 class="page-title">关于</h1>
    <div class="page-actions">
      <a
        class="icon-link"
        href="https://github.com/jialep38-png"
        aria-label="GitHub"
        title="GitHub"
      >
        <Icon name="github" class="icon" />
      </a>
      <a
        class="icon-link"
        href="mailto:jialep38@gmail.com"
        aria-label="Email"
        title="Email"
      >
        <Icon name="mail" class="icon" />
      </a>
    </div>
  </div>
  <p class="about-intro">
    你好，我是霁风。<br />
    这里是我的个人小圈，什么都会发。
  </p>

  <h2 class="section-title about-section-title">快速入口</h2>
  <div class="site-guide site-guide--compact">
    {quickLinkSections.map((section) => {
      const href = withBase(section.href);
      return (
        <article class="site-guide-item">
          <a class="site-guide-card-link" href={href} aria-label={`前往${section.label}`}>
            <div class="site-guide-head">
              <h3 class="site-guide-title">{section.label}</h3>
              <span class="site-guide-link">{section.href}</span>
            </div>
            <p class="site-guide-desc">{section.description}</p>
          </a>
        </article>
      );
    })}
  </div>



  <h2 class="section-title about-section-title">联系</h2>
  <section class="contact-block" aria-label="联系方式">
    <ul class="contact-list">
      <li>
        <span class="contact-link-head">
          <Icon name="mail" class="contact-icon" />
          <span>Email：</span>
        </span>
        <a href="mailto:jialep38@gmail.com">jialep38@gmail.com</a>
      </li>
      <li>
        <span class="contact-link-head">
          <Icon name="github" class="contact-icon" />
          <span>GitHub：</span>
        </span>
        <a href="https://github.com/jialep38-png">jialep38-png</a>
      </li>
    </ul>
  </section>

</BaseLayout>
